{
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "test": "pnpm -F @skillet-cli/core test",
    "test:unit": "pnpm -F @skillet-cli/core test:unit",
    "test:integration": "pnpm -F @skillet-cli/core test:integration",
    "test:e2e": "pnpm -F @skillet-cli/core test:e2e",
