{
  "name": "@skillet-cli/core",
  "version": "0.3.0",
  "description": "Ship your skill as an npm package with a complete CLI for any agent environment",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dafrick/skillet-cli.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/dafrick/skillet-cli",
  "bugs": {
    "url": "https://github.com/dafrick/skillet-cli/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "claude",
    "copilot",
    "cli",
    "skill-installer"
  ],
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "hello-skill": "bin/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts test/unit",
    "test:integration": "vitest run --config vitest.config.ts test/integration",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "lint": "pnpm exec biome check .",
    "format": "pnpm exec biome check --write .",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@inquirer/core": "^10.1.10",
    "@inquirer/prompts": "^7.5.2",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "figlet": "^1.8.0",
    "gray-matter": "^4.0.3",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@skillet-cli/ui": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.9.1",
    "@types/update-notifier": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.7",
    "cli-testing-library": "^3.0.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
