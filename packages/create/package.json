{
  "name": "create-skillet",
  "version": "0.3.0",
  "description": "Interactive wizard to package a skill for any AI agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dafrick/skillet-cli.git",
    "directory": "packages/create"
  },
  "homepage": "https://github.com/dafrick/skillet-cli",
  "bugs": {
    "url": "https://github.com/dafrick/skillet-cli/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "create-skillet": "./bin/cli.js"
  },
  "exports": {
    ".": "./dist/run.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "lint": "pnpm exec biome check .",
    "format": "pnpm exec biome check --write .",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.2",
    "@skillet-cli/core": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@skillet-cli/ui": "workspace:*",
    "@types/node": "^25.9.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
